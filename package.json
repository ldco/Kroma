{
  "name": "image-api-tool",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Prompt-driven staged image edits tool with safety gates and reproducible run logs.",
  "scripts": {
    "backend:init": "cd src-tauri && cargo run -- db:init",
    "backend:migrate": "cd src-tauri && cargo run -- db:init",
    "backend:user:local": "cd src-tauri && cargo run -- db:ensure-user --username local --display-name \"Local User\"",
    "backend:project:list": "cd src-tauri && cargo run -- backend:project:list",
    "backend:rust": "cd src-tauri && cargo run",
    "backend:rust:test": "cd src-tauri && cargo test",
    "backend:worker": "cd src-tauri && cargo run -- agent-worker",
    "backend:worker:once": "cd src-tauri && cargo run -- agent-worker --once",
    "backend:contract:smoke": "python3 scripts/contract_smoke.py",
    "realesrgan:setup": "python3 scripts/setup_tools.py realesrgan-ncnn",
    "realesrgan:python:setup": "python3 scripts/setup_tools.py realesrgan-python",
    "rembg:setup": "python3 scripts/setup_tools.py rembg",
    "tools:setup": "python3 scripts/setup_tools.py all"
  },
  "engines": {
    "node": ">=20"
  }
}
